{
  "name": "crown-mural-interactive",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run process:image && vite build",
    "build:vite-only": "vite build",
    "pip:install": "python -m pip install -r requirements.txt",
    "preview": "vite preview --open",
    "process:image": "python scripts/regions.py Mural_Crown_of_Italian_City.svg.png --blur 1 --close 1 --min_area 5 --canny_sigma 0.25 --mask_mode all --palette_mode kbatch --sample_step 7 --masks_dir public/data/shape_masks",
    "deploy": "npm run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@webgpu/types": "^0.1.68",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
